{
  "name": "@pitch-dog/pitch-dictionary",
  "version": "1.0.0",
  "description": "A fuzzy-searchable plain-English pitch dictionary from pitch.dog.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/bomkino/pitchdog-pitch-dictionary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bomkino/pitchdog-pitch-dictionary.git"
  },
  "bugs": {
    "url": "https://github.com/bomkino/pitchdog-pitch-dictionary/issues"
  },
  "keywords": ["pitching", "dictionary", "glossary", "fuzzy-search", "local-first"],
  "engines": {
    "node": ">=22.18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "build": "vite build && node scripts/build-sites-worker.mjs",
    "test:hosting": "node --test tests/hosting.test.mjs",
    "verify": "npm run check && npm run test && npm run build && npm run test:hosting"
  },
  "dependencies": {
    "matter-js": "^0.20.0"
  },
  "devDependencies": {
    "@types/matter-js": "^0.19.8",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.0"
  }
}
